# OpenAI direct (key from https://platform.openai.com/account/api-keys)
# Keys start with sk-proj- or sk-
OPENAI_API_KEY=sk-your-openai-key-here
LLM_PROVIDER=openai

# OpenRouter (key from https://openrouter.ai/keys) — keys start with sk-or-v1-
# OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here
# LLM_PROVIDER=openrouter
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# APP_NAME=Employee Chatbot
# APP_URL=http://localhost:3000

PORT=3000
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW_MS=60000

# Prompt safety limits to prevent long conversations from exhausting context tokens.
# Raise these only if your selected model/provider supports larger contexts.
MAX_PROMPT_TOKENS=8000
MAX_OUTPUT_TOKENS=700
MAX_CONTEXT_CHARS=8000
MAX_HISTORY_MESSAGES=12
